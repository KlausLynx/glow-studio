<section class="shop-teaser">
    <div class="shop-teaser__header">
        <h2>Where Beauty Meets Ritual</h2>
        <p>Thoughtfully curated products for women who care about what they put on their skin.</p>
    </div>
        {% assign featured_products = collections['hair-shop'].products %}
        <div class="shop-teaser__products">
            {% for product in featured_products %}
                <div class="shop-teaser__product">
                    <a href="{{ product.url }}" class="shop-teaser__product-link">
                        <img src="{{ product.featured_image | image_url: width: 800 }}" alt="{{ product.title }}" class="shop-teaser__product-image" width="800" height="800">
                    </a>
                    <h6 class="shop-teaser__product-title">{{ product.title }}</h6>
                </div>
            {% endfor %}
        </div>
        <div class="shop-teaser__cta">
            <a href="{{ collections['hair-shop'].url }}" class="shop-teaser__btn">
                <span>Shop The Elara Collection</span>
            </a>
        </div>
</section>

<style>
    .shop-teaser {
        background-color: var(--current-bg);
        padding: 5rem 2rem;
        overflow: hidden;
    }
    .shop-teaser__header {
        text-align: center;
        margin-bottom: 3rem;
    }

    .shop-teaser__header h2 {
        font-family: var(--font-heading);
        font-size: clamp(2rem, 5vw, 3.5rem);
        color: var(--current-text);
        letter-spacing: 0.1em;
        text-transform: uppercase;
        margin-bottom: 0.5rem;
        text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.1);
        text-align: start;
    }

    .shop-teaser__header p {
        font-family: var(--font-body);
        font-size: 1rem;
        color: var(--current-accent);
    }

    .shop-teaser__products {
        display: flex;
        flex-wrap: nowrap;
        overflow-x: auto;
        scroll-snap-type: x mandatory;
        gap: 1.5rem;
        padding-bottom: 1rem;
        -webkit-overflow-scrolling: touch;
        overflow-y: hidden;
    }

    .shop-teaser__products::-webkit-scrollbar {
        height: 4px;
    }

    .shop-teaser__products::-webkit-scrollbar-thumb {
        background: var(--current-accent);
        border-radius: 2px;
    }

    .shop-teaser__product {
        min-width: 280px;
        scroll-snap-align: start;
        flex-shrink: 0;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .shop-teaser__product-image {
        width: 100%;
        height: 200px;
        border-radius: 8px;
        background-position: center;
        background-size: cover;
    }

    .shop-teaser__product-title, 
    .shop-teaser__product-price {
        margin: 0px;
        font-family: var(--font-heading);
    }

    .shop-teaser__cta {
        text-align: center;
        margin-top: 3rem;
    }

    .shop-teaser__btn {
        display: inline-block;
        padding: 1rem 3rem;
        font-family: var(--font-body);
        font-size: 0.85rem;
        letter-spacing: 0.25em;
        text-transform: uppercase;
        text-decoration: none;
        background-color: var(--current-accent);
        border: 1px solid var(--current-accent);
        border-radius: 8px;
        transition: all 0.4s ease;
        position: relative;
        overflow: hidden;
        z-index: 0;
    }

    .shop-teaser__btn::before {
        content: '';
        position: absolute;
        inset: 0;
        background-color: var(--current-secondary);
        transform: translateX(-100%);
        transition: transform 0.4s ease;
        z-index: 1;
    }

    .shop-teaser__btn:hover::before {
        transform: translateX(0);
    }

    .shop-teaser__btn span {
        position: relative;
        z-index: 2;
        color: var(--current-text);
    }
</style>

<script>
    document.addEventListener('gsap:ready', function() {
        gsap.fromTo(".shop-teaser__header", 
        { y: -40, opacity: 0 },
        {
            y: 0,
            opacity: 1,
            duration: 0.8,
            ease: "power2.out",
            scrollTrigger: {
                trigger: ".shop-teaser__header",
                start: "top 90%",
                end: "top 30%",
                toggleActions: "play none none reverse"
            }
        }
        );

        gsap.fromTo(".shop-teaser__product",
            { y: 45, opacity: 0 },
            {
            y: 0,
            opacity: 1,
            duration: 0.6,
            stagger: 0.15,
            ease: "power2.out",
            scrollTrigger: {
                trigger: ".shop-teaser__products",
                start: "top 60%",
                end: "top 30%",
                toggleActions: "play none none reverse"
            }
            }
        );
    });
</script>
{% schema %}
{
    "name": "Elara Shop Teaser",
    "settings": []
}
{% endschema %}