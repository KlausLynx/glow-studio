<section>
    <div class="contact-hero">
        <h1>We'd Love to Hear from You</h1>
        <p class="contact-hero__description">Every great partnership begins with a single message. Share what's on your mind — we're always within reach.</p>
    </div>
</section>

<style>
    .contact-hero {
        padding: 60px 20px;
        background-color: var(--current-bg);
        color: var(--current-text);
        font-family: var(--font-heading);
        height: 40vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
    }


    .contact-hero h1::after {
        content: '';
        display: block;
        width: 60px;
        height: 1px;
        background-color: var(--current-accent);
        margin: 1rem auto 0;
    }

    .contact-hero h1 {
        font-size: 2.5em;
        margin-bottom: 20px;
        color: var(--current-text);
        font-family: var(--font-body);

    }
    .contact-hero__description {
        font-size: 1.2em;
        color: var(--current-accent);
    }
</style>

{% schema %}
{
    "name": "Contact Hero",
    "settings":[]
}
{% endschema %}