<section class="hair-shop-products">

    <div class="hair-shop-products__filters">
        <p class="hair-shop-products__count">{{ collection.all_products_count}} Products</p>
        <div class="hair-shop-products__sort">
            <label class="hair-shop-products__sort-label" for="sort-select">Sort by</label>
                <select id="sort-select" class="hair-shop-products__sort-select" onchange="window.location.href=this.value">
                    <option value="{{ collection.url }}?sort_by=manual" {% if collection.sort_by == 'manual' %}selected{% endif %}>Featured</option>
                    <option value="{{ collection.url }}?sort_by=price-ascending" {% if collection.sort_by == 'price-ascending' %}selected{% endif %}>Price: Low to High</option>
                    <option value="{{ collection.url }}?sort_by=price-descending" {% if collection.sort_by == 'price-descending' %}selected{% endif %}>Price: High to Low</option>
                    <option value="{{ collection.url }}?sort_by=title-ascending" {% if collection.sort_by == 'title-ascending' %}selected{% endif %}>A–Z</option>
                    <option value="{{ collection.url }}?sort_by=best-selling" {% if collection.sort_by == 'best-selling' %}selected{% endif %}>Best Selling</option>
                </select>
        </div>
    </div>

    <div class="hair-shop-products__grid">
        {% for product in collection.products %}
        <div class="hair-shop-products__card">
            <a href="{{ product.url }}" class="hair-shop-products__image-link">
            <div class="hair-shop-products__image-wrap">
                {% if product.featured_image %}
                <img
                    src="{{ product.featured_image | image_url: width: 600 }}"
                    alt="{{ product.title }}"
                    class="hair-shop-products__image"
                    width="600"
                    height="600"
                    loading="lazy"
                >
                {% else %}
                <div class="hair-shop-products__no-image">No image</div>
                {% endif %}
            </div>
            </a>
            <div class="hair-shop-products__info">
                <h3 class="hair-shop-products__name">
                    <a href="{{ product.url }}">{{ product.title }}</a>
                </h3>
                {% if product.variants.size > 1 %}
                    <p class="hair-shop-products__variants">{{ product.variants.size }} options</p>
                {% endif %}
                <p class="hair-shop-products__price">{{ product.price | money }}</p>
                <a href="{{ product.url }}" class="hair-shop-products__btn">
                    <span>Shop Now</span>
                </a>
            </div>
        </div>
    {% endfor %}
    </div>

</section>

<style>
  .hair-shop-products {
    background-color: var(--elara-light-bg);
    padding: 3rem 2rem 6rem;
  }

  /* Filters Bar */
  .hair-shop-products__filters {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(0,0,0,0.08);
  }

  .hair-shop-products__count {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: var(--elara-light-text);
    letter-spacing: 0.08em;
    margin: 0;
    opacity: 0.7;
  }

  .hair-shop-products__sort {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .hair-shop-products__sort-label {
    font-family: var(--font-body);
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--elara-light-text);
    opacity: 0.6;
  }

  .hair-shop-products__sort-select {
    background: transparent;
    border: 1px solid var(--elara-light-secondary);
    color: var(--elara-light-text);
    font-family: var(--font-body);
    font-size: 0.8rem;
    padding: 0.4rem 0.75rem;
    cursor: pointer;
    outline: none;
    border-radius: 2px;
    transition: border-color 0.3s ease;
  }

  .hair-shop-products__sort-select:focus {
    border-color: var(--elara-light-accent);
  }

  /* Product Grid */
  .hair-shop-products__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  /* Product Card */
  .hair-shop-products__card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .hair-shop-products__image-link {
    display: block;
    text-decoration: none;
  }

  .hair-shop-products__image-wrap {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background-color: #f5f0f0;
    border-radius: 2px;
  }

  .hair-shop-products__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .hair-shop-products__image-link:hover .hair-shop-products__image {
    transform: scale(1.05);
  }

  .hair-shop-products__no-image {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-body);
    font-size: 0.8rem;
    color: var(--elara-light-secondary);
  }

  /* Product Info */
  .hair-shop-products__info {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .hair-shop-products__name {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    margin: 0;
  }

  .hair-shop-products__name a {
    color: var(--elara-light-text);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .hair-shop-products__name a:hover {
    color: var(--elara-light-accent);
  }

  .hair-shop-products__variants {
    font-family: var(--font-body);
    font-size: 0.75rem;
    color: var(--elara-light-secondary);
    letter-spacing: 0.08em;
    margin: 0;
  }

  .hair-shop-products__price {
    font-family: var(--font-heading);
    font-size: 1.3rem;
    color: var(--elara-light-primary);
    margin: 0;
  }

  .hair-shop-products__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.7rem 1.5rem;
    border: 1px solid var(--elara-light-primary);
    color: var(--elara-light-primary);
    font-family: var(--font-body);
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    margin-top: 0.5rem;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .hair-shop-products__btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background-color: var(--elara-light-primary);
    transform: translateX(-100%);
    transition: transform 0.3s ease;
    z-index: 1;
  }

  .hair-shop-products__btn:hover::before {
    transform: translateX(0);
  }

  .hair-shop-products__btn span {
    position: relative;
    z-index: 2;
  }

  .hair-shop-products__btn:hover span {
    color: var(--elara-light-bg);
  }

  /* Mobile */
  @media (max-width: 768px) {
    .hair-shop-products__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.25rem;
    }
  }

  @media (max-width: 480px) {
    .hair-shop-products__grid {
      grid-template-columns: 1fr;
    }

    .hair-shop-products__filters {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }
  }
</style>

{% schema %}
{
  "name": "Hair Shop Products",
  "settings": []
}
{% endschema %}