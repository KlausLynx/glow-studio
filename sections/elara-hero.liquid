<div class="elara-hero">
  <div class="elara-hero__bg">
    <img src="https://cdn.shopify.com/s/files/1/0791/2878/9223/files/elara_1920x1920.jpg?v=1779027656" alt="Elara Hero Background" class="elara-hero__image" width="1920" height="1920">
  </div>
  <div class="elara-hero__overlay"></div>
  <div class="elara-hero__content">
    <h1 class="elara-hero__heading"></h1>
    <p class="elara-hero__tagline">Discover the beauty of simplicity.</p>
    <a href="#" class="elara-hero__btn">Shop Now</a>
  </div>
</div>

<style>
  .elara-hero {
    position: relative;
    width: 100%;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .elara-hero__bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .elara-hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .elara-hero__overlay {
    position: absolute;
    inset: 0;
    background-color: rgba(255, 255, 255, 0.07);
  }

  .elara-hero__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .elara-hero__heading,
  .elara-hero__tagline,
  .elara-hero__btn {
    opacity: 0;
  }

  .elara-hero__heading {
    font-family: var(--font-heading);
    font-size: clamp(4rem, 10vw, 8rem);
    color: var(--elara-light-text);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin: 0;
  }

  .elara-hero__tagline {
    font-family: var(--font-body);
    font-size: clamp(1rem, 2.5vw, 1.4rem);
    color: var(--elara-dark-accent);
    letter-spacing: 0.05em;
    margin: 0;
  }

  .elara-hero__btn {
    display: inline-block;
    padding: 0.75rem 2rem;
    font-family: var(--font-heading);
    font-size: 1rem;
    color: var(--elara-light-text);
    background-color: var(--elara-light-accent);
    text-decoration: none;
    border-radius: 4px;
    transition: background-color 0.3s ease;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    gsap.to('.elara-hero__image', { scale: 1.1, duration: 10, ease: 'power2.out' });
    gsap.to('.elara-hero__heading', { opacity: 1,  text: {
      value: 'Elara',
      delimiter: ''
    }, duration: 2, ease: 'none' });
    gsap.fromTo('.elara-hero__tagline', { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 1.5, delay: 2.5, ease: 'power2.out' });
    gsap.fromTo('.elara-hero__btn', { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 1.5, delay: 3, ease: 'power2.out' });
  })

  const btn = document.querySelector('.elara-hero__btn');
  btn.addEventListener('mouseenter', () => {
    gsap.to(btn, { backgroundColor: 'var(--elara-light-accent-hover)', duration: 0.3 });
  });
  btn.addEventListener('mouseleave', () => {
    gsap.to(btn, { backgroundColor: 'var(--elara-light-accent)', duration: 0.3 });
  });
</script>

{% schema %}
{
  "name": "Elara Hero",
  "settings": []
}
{% endschema %}