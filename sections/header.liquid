<header class="glow-header" id="glow-header">
  <div class="glow-header__wrapper">

    <!-- Logo -->
    <a href="{{ routes.root_url }}" class="glow-header__logo">
      <img
        src="https://cdn.shopify.com/s/files/1/0791/2878/9223/files/logo_1200x1200.png?v=1779956020"
        alt="Glow Studio"
        width="120"
        height="120"
      >
    </a>

    <!-- Navigation -->
    <nav class="glow-header__nav">
      <a href="/pages/knox-room" class="glow-header__link">Knox</a>
      <a href="/pages/elara-room" class="glow-header__link">Elara</a>
      <a href="{{ collections['hair-shop'].url }}" class="glow-header__link">Hair Shop</a>
      <a href="/pages/contact" class="glow-header__link">Contact</a>
    </nav>

    <!-- Right Side Actions -->
    <div class="glow-header__actions">
      <!-- Search -->
      <button class="glow-header__icon-btn" id="glow-search-btn" aria-label="Search">
        <i class="fa-solid fa-magnifying-glass"></i>
      </button>

      <!-- Cart -->
      <a href="{{ routes.cart_url }}" class="glow-header__icon-btn glow-header__cart" aria-label="Cart">
        <i class="fa-solid fa-bag-shopping"></i>
        <span class="glow-header__cart-count" id="cart-count">{% if cart.item_count > 0 %}{{ cart.item_count }}{% endif %}</span>
      </a>

      <a href="https://calendly.com/onyiavitus" target="_blank" class="glow-header__book-btn">
        <span>Book Now</span>
      </a>

      <button class="glow-header__toggle" id="theme-toggle" aria-label="Toggle dark/light mode">
        <i class="fa-solid fa-moon" id="theme-icon"></i>
      </button>
    </div>

    <!-- Mobile Hamburger -->
    <button class="glow-header__hamburger" id="glow-hamburger" aria-label="Open menu">
      <span></span>
      <span></span>
      <span></span>
    </button>

  </div>

  <!-- Mobile Drawer -->
  <div class="glow-header__drawer" id="glow-drawer">
    <div class="glow-header__drawer-links">
      <a href="/pages/knox-room" class="glow-header__drawer-link">Knox</a>
      <a href="/pages/elara-room" class="glow-header__drawer-link">Elara</a>
      <a href="{{ collections['hair-shop'].url }}" class="glow-header__drawer-link">Hair Shop</a>
      <a href="/pages/contact" class="glow-header__drawer-link">Contact</a>
      <a href="{{ routes.cart_url }}" class="glow-header__drawer-link">
        Cart 
        {% if cart.item_count > 0 %}
          ({{ cart.item_count }})
        {% endif %}
      </a>
      <a href="https://calendly.com/onyiavitus" target="_blank" class="glow-header__drawer-book">Book Now</a>

      <button class="glow-header__drawer-toggle" id="theme-toggle-mobile" aria-label="Toggle dark/light mode">
        <i class="fa-solid fa-moon" id="theme-icon-mobile"></i>
        <span>Dark Mode</span>
      </button>
    </div>
  </div>
</header>
<style>
  /* 
    ============================================
      GLOW HEADER
    ============================================ 
  */
  .glow-header {
    position: sticky;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background-color: var(--current-bg);
    border-bottom: 1px solid var(--current-border);
    transition: background-color 0.3s ease, border-color 0.3s ease;
  }

  .glow-header__wrapper {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 2rem;
    max-width: 1400px;
    margin: 0 auto;
  }

  /* Logo */
  .glow-header__logo img {
    height: 70px;
    width: auto;
    display: block;
  }
  /* Nav */
  .glow-header__nav {
    display: flex;
    align-items: center;
    gap: 2.5rem;
  }

  .glow-header__link {
    font-family: var(--font-body);
    font-size: 0.85rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--current-text);
    transition: color 0.3s ease;
    position: relative;
  }

  .glow-header__link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 1px;
    background-color: var(--current-accent);
    transition: width 0.3s ease;
  }

  .glow-header__link:hover {
    color: var(--current-accent);
  }

  .glow-header__link:hover::after {
    width: 100%;
  }

  /* Actions */
  .glow-header__actions {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .glow-header__icon-btn {
  background: transparent;
  border: none;
  cursor: pointer;
  color: var(--current-text);
  font-size: 1.1rem;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  position: relative;
  text-decoration: none;
  transition: color 0.3s ease;
}

.glow-header__icon-btn:hover {
  color: var(--current-accent);
}

/* Cart count badge */
.glow-header__cart {
  position: relative;
}

.glow-header__cart-count {
  position: absolute;
  top: -4px;
  right: -4px;
  background-color: var(--current-accent);
  color: var(--current-bg);
  font-family: var(--font-body);
  font-size: 0.65rem;
  font-weight: 700;
  width: 16px;
  height: 16px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

/* Hide count when 0 */
.glow-header__cart-count:empty {
  display: none;
}

  /* Book Now Button */
  .glow-header__book-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.6rem 1.5rem;
    border: 1px solid var(--current-accent);
    color: var(--current-accent);
    font-family: var(--font-body);
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    text-decoration: none;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .glow-header__book-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background-color: var(--current-accent);
    transform: translateX(-100%);
    transition: transform 0.3s ease;
    z-index: 1;
  }

  .glow-header__book-btn:hover::before {
    transform: translateX(0);
  }

  .glow-header__book-btn span {
    position: relative;
    z-index: 2;
  }

  .glow-header__book-btn:hover span {
    color: var(--current-bg);
  }

  /* Toggle Button */
  .glow-header__toggle {
    background: transparent;
    border: 1px solid var(--current-accent);
    color: var(--current-accent);
    width: 36px;
    height: 36px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.9rem;
    transition: all 0.3s ease;
  }

  .glow-header__toggle:hover {
    background-color: var(--current-accent);
    color: var(--current-bg);
  }

  /* Hamburger */
  .glow-header__hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .glow-header__hamburger span {
    display: block;
    width: 24px;
    height: 1.5px;
    background-color: var(--current-text);
    transition: all 0.3s ease;
  }

  .glow-header__hamburger.is-open span:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }

  .glow-header__hamburger.is-open span:nth-child(2) {
    opacity: 0;
  }

  .glow-header__hamburger.is-open span:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  /* Mobile Drawer */
  .glow-header__drawer {
    display: none;
    padding: 1.5rem 2rem;
    border-top: 1px solid var(--current-border);
    background-color: var(--current-bg);
  }

  .glow-header__drawer.is-open {
    display: block;
  }

  .glow-header__drawer-links {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .glow-header__drawer-link {
    font-family: var(--font-body);
    font-size: 0.9rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--current-text);
    transition: color 0.3s ease;
  }

  .glow-header__drawer-link:hover {
    color: var(--current-accent);
  }

  .glow-header__drawer-book {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    border: 1px solid var(--current-accent);
    color: var(--current-accent);
    font-family: var(--font-body);
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    text-decoration: none;
    text-align: center;
    margin-top: 0.5rem;
    transition: all 0.3s ease;
  }

  .glow-header__drawer-book:hover {
    background-color: var(--current-accent);
    color: var(--current-bg);
  }

.glow-header__drawer-toggle {
  background: transparent;
  border: 1px solid var(--current-accent);
  color: var(--current-accent);
  padding: 0.6rem 1.25rem;
  border-radius: 50px;
  cursor: pointer;
  font-family: var(--font-body);
  font-size: 0.75rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  display: flex;
  align-items: center;
  gap: 0.5rem;
  width: fit-content;
  transition: all 0.3s ease;
}

.glow-header__drawer-toggle:hover {
  background-color: var(--current-accent);
  color: var(--current-bg);
}

  /* Mobile */
  @media (max-width: 768px) {
    .glow-header__actions {
      display: none;
    }

    .glow-header__hamburger {
      display: flex;
    }

    .glow-header__nav {
      display: none;  /* hide nav */
    }

    .glow-header__actions {
      display: flex;  /* keep actions visible */
    }

    /* Hide everything except the toggle */
    .glow-header__actions > *:not(.glow-header__toggle) {
      display: none;
    }
}
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {

    // Search modal
    document.getElementById('glow-search-btn').addEventListener('click', function() {
      const searchModal = document.querySelector('#search-modal')
      if (searchModal) {
        searchModal.querySelector('dialog')?.showModal()
      }
    })

    // Mobile hamburger
    const hamburger = document.getElementById('glow-hamburger')
    const drawer = document.getElementById('glow-drawer')
    hamburger.addEventListener('click', function() {
      hamburger.classList.toggle('is-open')
      drawer.classList.toggle('is-open')
    })

  });

</script>
<script src="{{ 'cart-count.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Header",
  "settings": []
}
{% endschema %}