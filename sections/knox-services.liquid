<section class="knox-services">
  <div class="knox-services__header">
    <h2 class="knox-services__title">Our Services</h2>
    <p class="knox-services__subtitle">Crafted for the modern man.</p>
  </div>

  <div class="knox-services__grid">
    {% assign services = "Classic Cut,30 mins,4500,https://cdn.shopify.com/s/files/1/0791/2878/9223/files/classic_800x800.jpg?v=1778979916|Fade & Design,45 mins,6500,https://cdn.shopify.com/s/files/1/0791/2878/9223/files/fade_800x800.jpg?v=1778980395|Cut & Beard Trim,50 mins,8000,https://cdn.shopify.com/s/files/1/0791/2878/9223/files/beard_800x800.jpg?v=1778979909|Hot Towel Shave,30 mins,5000,https://cdn.shopify.com/s/files/1/0791/2878/9223/files/hot_800x800.jpg?v=1778979910|Kids Cut,25 mins,3500,https://cdn.shopify.com/s/files/1/0791/2878/9223/files/kids_800x800.jpg?v=1778979932|Hair & Scalp Treatment,45 mins,7500,https://cdn.shopify.com/s/files/1/0791/2878/9223/files/scalp_800x800.jpg?v=1778979928|Home Service,60 mins,15000,https://cdn.shopify.com/s/files/1/0791/2878/9223/files/home_800x800.jpg?v=1778979913" | split: "|" %}

    {% for service in services %}
      {% assign details = service | split: "," %}
      <div class="knox-services__card">
        <div class="knox-services__image-wrap">
          <img
            src="{{ details[3] }}"
            alt="{{ details[0] }}"
            class="knox-services__image"
            loading="lazy"
            height="200"
            width="400"
          >
        </div>
        <div class="knox-services__card-body">
          <div class="knox-services__card-top">
            <h3 class="knox-services__name">{{ details[0] }}</h3>
            <span class="knox-services__duration">{{ details[1] }}</span>
          </div>
          <p class="knox-services__price">₦{{ details[2] }}</p>
          <a href="https://calendly.com/onyiavitus" target="_blank" class="knox-services__btn">Book Now</a>
        </div>
      </div>
    {% endfor %}
  </div>
</section>

<style>
  .knox-services {
    background-color: var(--current-bg);
    padding: 5rem 2rem;
  }

  .knox-services__header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .knox-services__title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 3.5rem);
    color: var(--current-text);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .knox-services__subtitle {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--current-accent);
    letter-spacing: 0.05em;
  }

  .knox-services__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .knox-services__card {
    background-color: var(--current-bg);
    border: 1px solid var(--current-border);
    border-radius: 4px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    opacity: 0;
    transform: translateY(40px);
    transition: transform 0.3s ease, border-color 0.3s ease;
  }

  .knox-services__card:hover {
    transform: translateY(-4px);
    border-color: var(--current-accent);
  }

  .knox-services__card.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .knox-services__image-wrap {
    width: 100%;
    height: 200px;
    overflow: hidden;
  }

  .knox-services__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .knox-services__card:hover .knox-services__image {
    transform: scale(1.05);
  }

  .knox-services__card-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    flex: 1;
  }

  .knox-services__card-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  .knox-services__name {
    font-family: var(--font-heading);
    font-size: 1.2rem;
    color: var(--current-text);
    margin: 0;
  }

  .knox-services__duration {
    font-family: var(--font-body);
    font-size: 0.75rem;
    color: var(--current-secondary);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .knox-services__price {
    font-family: var(--font-heading);
    font-size: 1.8rem;
    color: var(--current-accent);
    margin: 0;
  }

  .knox-services__btn {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    border: 1px solid var(--current-accent);
    color: var(--current-accent);
    font-family: var(--font-body);
    font-size: 0.8rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    text-decoration: none;
    text-align: center;
    transition: all 0.3s ease;
    margin-top: auto;
  }

  .knox-services__btn:hover {
    background-color: var(--current-accent);
    color: var(--current-bg);
  }

  @media (max-width: 768px) {
    .knox-services__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .knox-services__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const cards = document.querySelectorAll('.knox-services__card');

    const observer = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry, index) {
          if (entry.isIntersecting) {
            setTimeout(function () {
              entry.target.style.transition = 'opacity 0.6s ease, transform 0.6s ease, border-color 0.3s ease';
              entry.target.classList.add('is-visible');
            }, index * 120);
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1 }
    );

    cards.forEach(function (card) {
      observer.observe(card);
    });
  });
</script>

{% schema %}
{
  "name": "Knox Services",
  "settings": []
}
{% endschema %}