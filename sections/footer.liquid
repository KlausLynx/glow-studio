<footer class="glow-footer">

  <!-- Top Section — Brand + Links + Social -->
  <div class="glow-footer__top">

    <!-- Left — Brand -->
    <div class="glow-footer__brand">
      <h3 class="glow-footer__logo">Glow Studio</h3>
      <p class="glow-footer__tagline">Unisex Hair & Beauty</p>
      <div class="glow-footer__contact-info">
        <p><i class="fa-solid fa-location-dot"></i> 123 Glow Avenue, Lagos, Nigeria</p>
        <p><i class="fa-solid fa-phone"></i> +234 800 000 0000</p>
        <p><i class="fa-solid fa-envelope"></i> hello@glowstudio.com</p>
        <p><i class="fa-solid fa-clock"></i> Mon–Sat: 9am – 7pm | Sun: 11am – 5pm</p>
      </div>
    </div>

    <!-- Right — Quick Links + Social -->
    <div class="glow-footer__right">

      <!-- Quick Links -->
      <div class="glow-footer__links">
        <p class="glow-footer__section-title">Quick Links</p>
        <ul>
          <li><a href="{{ routes.root_url }}">Home</a></li>
          <li><a href="{{ pages['knox-room'].url }}">Knox</a></li>
          <li><a href="{{ pages['elara-room'].url }}">Elara</a></li>
          <li><a href="{{ collections['hair-shop'].url }}">Hair Shop</a></li>
          <li><a href="{{ routes.contact_url }}">Contact</a></li>
        </ul>
      </div>

      <!-- Social -->
      <div class="glow-footer__social">
        <p class="glow-footer__section-title">Follow Us</p>
        <div class="glow-footer__social-links">
          <a href="https://instagram.com/glowstudio" target="_blank" referrerpolicy="no-referrer" class="glow-footer__social-link">
            <i class="fa-brands fa-instagram"></i>
            <span>Instagram</span>
          </a>
          <a href="https://tiktok.com/@glowstudio" target="_blank" referrerpolicy="no-referrer" class="glow-footer__social-link">
            <i class="fa-brands fa-tiktok"></i>
            <span>TikTok</span>
          </a>
        </div>
      </div>

    </div>

  </div>

  <!-- Divider -->
  <div class="glow-footer__divider"></div>

  <!-- Middle — Newsletter -->
  <div class="glow-footer__newsletter">
    <div class="glow-footer__newsletter-content">
      <div class="glow-footer__newsletter-text">
        <h4 class="glow-footer__newsletter-title">Join The Glow</h4>
        <p class="glow-footer__newsletter-desc">Subscribe for the latest updates and exclusive offers.</p>
      </div>
      {%- form 'customer', class: 'glow-footer__newsletter-form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        {%- if form.posted_successfully? -%}
          <p class="glow-footer__newsletter-success">Thank you for subscribing!</p>
        {%- else -%}
          <div class="glow-footer__newsletter-fields">
            <input
              type="email"
              name="contact[email]"
              placeholder="your@email.com"
              required
              class="glow-footer__newsletter-input"
            >
            <button type="submit" class="glow-footer__newsletter-btn">
              <span>Join</span>
            </button>
          </div>
        {%- endif -%}
      {%- endform -%}
    </div>
  </div>

  <!-- Divider -->
  <div class="glow-footer__divider"></div>

  <!-- Bottom — Copyright -->
  <div class="glow-footer__bottom">
    <p class="glow-footer__copyright">© 2025 Glow Studio. All rights reserved.</p>
    <p class="glow-footer__credits">Crafted with care for Knox & Elara.</p>
  </div>

</footer>

<style>
  .glow-footer {
    background-color: var(--current-bg);
    padding: 5rem 2rem 2rem;
    font-family: var(--font-body);
    color: var(--current-text);
    border-top: 1px solid var(--current-border);
  }

  /* Top Section */
  .glow-footer__top {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 4rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  /* Brand */
  .glow-footer__logo {
    font-family: var(--font-heading);
    font-size: 2rem;
    color: var(--current-text);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin: 0 0 0.5rem;
  }

  .glow-footer__tagline {
    font-size: 0.85rem;
    color: var(--current-text);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin: 0 0 2rem;
  }

  .glow-footer__contact-info p {
    font-size: 0.9rem;
    color: var(--current-text); 
    margin: 0 0 0.85rem;
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    line-height: 1.5;
  }

  .glow-footer__contact-info i {
    margin-top: 3px;
    min-width: 16px;
  }

  /* Right Side */
  .glow-footer__right {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .glow-footer__section-title {
    font-family: var(--font-body);
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin: 0 0 1.25rem;
    font-weight: 600;
  }

  /* Quick Links */
  .glow-footer__links ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .glow-footer__links li {
    margin-bottom: 0.75rem;
  }

  .glow-footer__links a {
    font-size: 0.9rem;
    text-decoration: none;
    letter-spacing: 0.05em;
    transition: color 0.3s ease;
    position: relative;
  }

  .glow-footer__links a::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1px;
    background-color: var(--current-accent);
    transition: width 0.3s ease;
  }

  .glow-footer__links a:hover {
    background: transparent;
  }

  .glow-footer__links a:hover::after {
    width: 100%;
  }

  /* Social */
  .glow-footer__social-links {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .glow-footer__social-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.3s ease;
  }

  .glow-footer__social-link i {
    font-size: 1.2rem;
    transition: transform 0.3s ease;
  }

  .glow-footer__social-link:hover {
  }

  .glow-footer__social-link:hover i {
    transform: scale(1.2);
  }

  /* Divider */
  .glow-footer__divider {
    max-width: 1200px;
    margin: 3rem auto;
    height: 1px;
    background-color: var(--current-border);
    opacity: 0.3;
  }

  /* Newsletter */
  .glow-footer__newsletter {
    max-width: 1200px;
    margin: 0 auto;
  }

  .glow-footer__newsletter-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .glow-footer__newsletter-title {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    letter-spacing: 0.1em;
    margin: 0 0 0.5rem;
  }

  .glow-footer__newsletter-desc {
    font-size: 0.85rem;
    margin: 0;
  }

  .glow-footer__newsletter-fields {
    display: flex;
    gap: 0;
    flex: 1;
    max-width: 400px;
  }

  .glow-footer__newsletter-input {
    flex: 1;
    background: transparent;
    border: 1px solid var(--current-secondary);
    border-right: none;
    padding: 0.85rem 1.25rem;
    font-family: var(--font-body);
    font-size: 0.85rem;
    outline: none;
    transition: border-color 0.3s ease;
  }

  .glow-footer__newsletter-input::placeholder {
    color: var(--current-secondary);
  }

  .glow-footer__newsletter-input:focus {
    border-color: var(--current-border);
  }

  .glow-footer__newsletter-btn {
    padding: 0.85rem 1.75rem;
    background-color: var(--current-accent);
    border: 1px solid var(--current-border);
      color: var(--current-text);
    font-family: var(--font-body);
    font-size: 0.8rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .glow-footer__newsletter-btn:hover {
    background-color: transparent;
    color: var(--current-text);
  }

  .glow-footer__newsletter-success {
    font-size: 0.9rem;
    margin: 0;
  }

  /* Bottom */
  .glow-footer__bottom {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .glow-footer__copyright,
  .glow-footer__credits {
    font-size: 0.8rem;
    margin: 0;
    letter-spacing: 0.05em;
  }

  /* Mobile */
  @media (max-width: 768px) {
    .glow-footer__top {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .glow-footer__right {
      grid-template-columns: 1fr 1fr;
    }

    .glow-footer__newsletter-content {
      flex-direction: column;
      align-items: flex-start;
    }

    .glow-footer__newsletter-fields {
      width: 100%;
      max-width: 100%;
    }

    .glow-footer__bottom {
      flex-direction: column;
      gap: 0.5rem;
      text-align: center;
    }
  }

  @media (max-width: 480px) {
    .glow-footer__right {
      grid-template-columns: 1fr;
    }
  }
</style>

{% schema %}
{
  "name": "Footer",
  "settings": []
}
{% endschema %}